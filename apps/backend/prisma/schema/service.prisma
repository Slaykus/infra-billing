model Service {
  uuid String @id @default(uuid()) @map("uuid")

  providerUuid   String    @map("provider_uuid")
  projectUuid    String    @map("project_uuid")
  name           String    @map("name")
  type           String    @map("type")
  externalId     String?   @map("external_id")
  countryCode    String?   @default("XX") @map("country_code")
  cost           Decimal   @db.Decimal(14, 2) @map("cost")
  currency       String    @map("currency")
  period         String    @map("period")
  nextBillingAt  DateTime? @map("next_billing_at")
  isActive       Boolean   @default(true) @map("is_active")
  isManaged      Boolean   @default(false) @map("is_managed")
  costOverridden Boolean   @default(false) @map("cost_overridden")
  nameOverridden Boolean   @default(false) @map("name_overridden")
  meta           Json      @default("{}") @map("meta")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  provider Provider  @relation(fields: [providerUuid], references: [uuid], onDelete: Cascade)
  project  Project   @relation(fields: [projectUuid], references: [uuid], onDelete: Restrict)
  payments Payment[]

  @@unique([providerUuid, externalId], map: "services_provider_external_id_key")
  @@index([providerUuid], map: "services_provider_uuid_idx")
  @@index([projectUuid], map: "services_project_uuid_idx")
  @@map("services")
}

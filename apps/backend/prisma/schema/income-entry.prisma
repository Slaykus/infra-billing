model IncomeEntry {
  uuid String @id @default(uuid()) @map("uuid")

  // Receipt payment_id from the receipts service; null for manually-entered income.
  externalId String? @map("external_id")
  // "moy-nalog" (synced from the receipts service) | "manual"
  source     String  @default("moy-nalog") @map("source")

  amount      Decimal  @db.Decimal(14, 2) @map("amount")
  currency    String   @default("RUB") @map("currency")
  description String?  @map("description")
  incomeDate  DateTime @map("income_date")
  // SENT = filed/confirmed, PENDING = awaiting, DEAD = failed (mirrors the receipts service).
  status      String   @default("SENT") @map("status")
  receiptLink String?  @map("receipt_link")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([source, externalId], map: "income_entries_source_external_id_key")
  @@index([incomeDate], map: "income_entries_income_date_idx")
  @@index([status], map: "income_entries_status_idx")
  @@map("income_entries")
}
